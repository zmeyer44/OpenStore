# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/locker

# ── Authentication (BetterAuth) ──────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Blob Storage ─────────────────────────────────────────────────────────────
# Provider: local | s3 | r2 | vercel
BLOB_STORAGE_PROVIDER=local

# Local storage directory (when provider=local)
LOCAL_BLOB_DIR=./local-blobs

# AWS S3 (when provider=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=locker

# Cloudflare R2 (when provider=r2)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=locker
# R2_PUBLIC_URL=

# Vercel Blob (when provider=vercel)
# BLOB_READ_WRITE_TOKEN=

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Email (Resend) ──────────────────────────────────────────────────────────
# RESEND_API_KEY=

# ── Plugin Secret Encryption ─────────────────────────────────────────────────
# Required in production. Must be stable — rotating this breaks stored plugin secrets.
# PLUGIN_ENCRYPTION_SECRET=your-stable-secret-here

# ── Storage Limits ───────────────────────────────────────────────────────────
# Max file size in bytes (default: 100MB)
# MAX_FILE_SIZE=104857600
# Max storage per user in bytes (default: 5GB)
# MAX_STORAGE_PER_USER=5368709120

# ── AI Gateway (Document Transcription) ─────────────────────────────────
# API key for the Vercel AI Gateway. Required for the built-in document
# transcription plugin to work without an external service URL.
# AI_GATEWAY_API_KEY=
# Default model for transcription (provider/model format, e.g. "openai/gpt-4o")
# AI_GATEWAY_MODEL=openai/gpt-4o

# ── QMD Search Service ──────────────────────────────────────────────────────
# URL of the QMD search service (run via Docker Compose or standalone)
# QMD_SERVICE_URL=http://localhost:9600
# Shared secret for authenticating requests between Locker and QMD service
# Generate with: openssl rand -base64 32
# QMD_API_SECRET=your-shared-secret-here

# ── FTS Search Service ──────────────────────────────────────────────────────
# URL of the FTS full-text search service
# FTS_SERVICE_URL=http://localhost:9700
# Shared secret for authenticating requests between Locker and FTS service
# Generate with: openssl rand -base64 32
# FTS_API_SECRET=your-shared-secret-here
