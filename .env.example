# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openstore

# ── Authentication (BetterAuth) ──────────────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Blob Storage ─────────────────────────────────────────────────────────────
# Provider: local | s3 | r2 | vercel
BLOB_STORAGE_PROVIDER=local

# Local storage directory (when provider=local)
LOCAL_BLOB_DIR=./local-blobs

# AWS S3 (when provider=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=openstore

# Cloudflare R2 (when provider=r2)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=openstore
# R2_PUBLIC_URL=

# Vercel Blob (when provider=vercel)
# BLOB_READ_WRITE_TOKEN=

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Email (Resend) ──────────────────────────────────────────────────────────
# RESEND_API_KEY=

# ── Storage Limits ───────────────────────────────────────────────────────────
# Max file size in bytes (default: 100MB)
# MAX_FILE_SIZE=104857600
# Max storage per user in bytes (default: 5GB)
# MAX_STORAGE_PER_USER=5368709120
